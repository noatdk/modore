# Copy to ~/.config/modore/modore.conf (same path regardless of distro).
#
# See docs/configuration.md for the full behavior of each key and
# PARITY.md for the live feature matrix.
#
# Electron / Chromium under Hyprland:
# • If DISPLAY is set (usual XWayland case), ipc pickup prefers XTest — often works without extra tweaks.
# • Pure Oz/Wayland Chromium (DISPLAY unset): keep DISPLAY in your session if possible, or rely on Hypr+wtype clipboard paths + modore-host --ipc-only trigger.

[conversion]

# Available: macOS, Linux
# Trigger chord. Modifiers + a single key, joined with `+`.
hotkey = Ctrl+Shift+grave

# Available: macOS
# Which Mozc backend the macOS host should use.
#   oss         = bundled in-process OSS Mozc engine (default)
#   google_ime  = preinstalled Google Japanese Input service
# Note: google_ime currently depends on app-bundle launch context; if bridge
# init fails, switch back to `oss`.
# mozc_backend = oss

# Available: macOS
# Extra modifier on top of `hotkey` that forces a katakana commit
# instead of the usual top-kanji candidate. Useful for loanwords Mozc
# keeps writing as kanji ("シドッチ" vs "史奉行"). One of: none, shift.
# katakana_modifier = shift

# Available: macOS
# How long after a conversion Esc still reverts it back to the original
# reading. Default 5000 (5 s). Set to 0 to disable Esc-undo entirely;
# max 30000.
# undo_window_ms = 5000

# Available: macOS
# Timings for the clipboard fallback path (used when the focused app
# doesn't expose Accessibility text, e.g. Chromium/Electron). Defaults
# shown; uncomment and adjust if force-select copies are flaky.
# See docs/configuration.md → [clipboard] for what each knob controls.
# [clipboard]
# pre_copy_delay_ms = 20
# read_timeout_ms = 250
# restore_clipboard_delay_ms = 50
